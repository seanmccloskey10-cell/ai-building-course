# ---------------------------------------------------------------------------
# COPY THIS FILE TO `.env` AND PUT YOUR REAL KEY IN THE COPY.
#
# Leave this example file exactly as it is. It is committed to GitHub on
# purpose, so that anyone cloning this project can see WHICH variable they
# need to set - without ever seeing anyone's actual key.
#
# The `.env` file you create is listed in .gitignore, so it stays on your
# machine and never reaches GitHub.
#
# Get your key at https://console.anthropic.com -> API keys.
# It starts with sk-ant- and it is shown to you exactly once.
# ---------------------------------------------------------------------------

ANTHROPIC_API_KEY=sk-ant-replace-this-whole-thing-with-your-real-key
