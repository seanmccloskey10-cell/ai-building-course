# ---------------------------------------------------------------------------
# This project has no secrets, but the habit is worth keeping: if you ever add
# a .env file to a project, this line stops it reaching GitHub. It travels with
# the folder so you're protected from your first commit onward.
# ---------------------------------------------------------------------------
.env
.env.*

# Installed packages - `npm install` recreates these
node_modules/

# Netlify's local, machine-specific state
.netlify

# Editor + OS junk
.vscode/
.idea/
.DS_Store
Thumbs.db
