# ---------------------------------------------------------------------------
# This project has no secrets — the whole point is that its data source needs
# no API key. But the habit is worth keeping: if you ever add a .env to a
# project, this line stops it reaching GitHub. It travels with the folder.
# ---------------------------------------------------------------------------
.env
.env.*

# Installed packages - `npm install` recreates these
node_modules/

# Netlify's local, machine-specific state
.netlify

# Editor + OS junk
.vscode/
.idea/
.DS_Store
Thumbs.db
