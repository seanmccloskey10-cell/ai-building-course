# ---------------------------------------------------------------------------
# COPY THIS FILE TO `.env` AND FILL IN YOUR OWN VALUES.
#
# Leave this example file as it is (it's committed to GitHub on purpose, with
# no real values). The `.env` you create is gitignored and stays private.
# ---------------------------------------------------------------------------

# Your Anthropic key, for the AI that picks and summarizes the stories.
# Get one at https://console.anthropic.com  ->  API keys.
# You'll need a few dollars of credit under Billing (a daily digest costs pennies).
# NOTE: a Claude.ai subscription is NOT API credit - they're billed separately.
ANTHROPIC_API_KEY=

# Your Resend key, for sending the email.
# Get one at https://resend.com  ->  API Keys. The free tier is generous
# (100 emails/day) and needs no card.
RESEND_API_KEY=

# The email address the digest is sent TO. Use your own to start.
# On a free Resend account (no custom domain) you can only send to the email
# you signed up with - which is perfect for a personal digest.
EMAIL_TO=

# Set this to  true  to actually send the email. Leave it as  false  (or blank)
# to just generate the HTML files without sending - safe while you're testing.
SEND_EMAIL=false
